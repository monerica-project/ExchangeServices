<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>ExchangeServices.Console</RootNamespace>
    <AssemblyName>ExchangeServices.Console</AssemblyName>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.Hosting" Version="10.0.7" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ExchangeServices\ExchangeServices.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="appsettings.json" CopyToOutputDirectory="PreserveNewest" />
    <!-- Optional local file for API keys; never committed. -->
    <Content Include="appsettings.Secrets.json" Condition="Exists('appsettings.Secrets.json')" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
